<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or site.name }} | {{ site.name }}</title>
  <meta name="description" content="{{ description or site.specialty }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  
  <!-- Open Graph -->
  <meta property="og:title" content="{{ title or site.name }}">
  <meta property="og:description" content="{{ description or site.specialty }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}/assets/og-image.jpg">
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or site.name }}">
  <meta name="twitter:description" content="{{ description or site.specialty }}">
  <meta name="twitter:image" content="{{ site.url }}/assets/og-image.jpg">
  
  <!-- Preconnect to Unsplash CDN -->
  <link rel="preconnect" href="https://images.unsplash.com">
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
  
  <!-- Structured Data (Schema.org) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "{{ site.name }}",
    "description": "{{ site.specialty }}",
    "url": "{{ site.url }}",
    "email": "{{ site.email }}",
    "telephone": "{{ site.phone }}",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "{{ site.city }}",
      "addressCountry": "IN"
    }
  }
  </script>
  
  <style>
    /* CSS Custom Properties */
    :root {
      --primary-color: #1a2a4a;
      --secondary-color: #d4af37;
      --accent-color: #f5f0e8;
      --text-color: #1a1a1a;
      --text-light: #666666;
      --border-color: #e0d5c7;
      --shadow: 0 10px 40px rgba(26, 42, 74, 0.1);
      --shadow-hover: 0 20px 60px rgba(26, 42, 74, 0.15);
      --spacing-base: 8px;
      --spacing-section: 80px;
    }

    /* Typography */
    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      padding: 0;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-size: 16px;
      font-weight: 400;
      line-height: 1.6;
      color: var(--text-color);
      background-color: #fafbf9;
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -0.015em;
      margin: 0;
    }

    h1 {
      font-size: 40px;
    }

    h2 {
      font-size: 24px;
      margin-bottom: calc(var(--spacing-base) * 6);
    }

    h3 {
      font-size: 20px;
      margin-bottom: calc(var(--spacing-base) * 4);
    }

    p {
      margin: 0 0 calc(var(--spacing-base) * 2) 0;
    }

    a {
      color: var(--secondary-color);
      text-decoration: none;
      transition: color 0.35s ease;
    }

    a:hover {
      color: var(--primary-color);
    }

    /* Layout */
    section {
      padding: var(--spacing-section) calc(var(--spacing-base) * 4);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 calc(var(--spacing-base) * 4);
    }

    .section-header {
      text-align: center;
      margin-bottom: calc(var(--spacing-base) * 10);
      max-width: 680px;
      margin-left: auto;
      margin-right: auto;
    }

    .eyebrow {
      font-size: 12px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--secondary-color);
      margin-bottom: calc(var(--spacing-base) * 2);
      display: block;
    }

    .lead {
      font-size: 18px;
      color: var(--text-light);
      margin-top: calc(var(--spacing-base) * 3);
    }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: calc(var(--spacing-base) * 2);
      padding: 16px calc(var(--spacing-base) * 4);
      border-radius: 999px;
      font-weight: 600;
      font-size: 16px;
      cursor: pointer;
      transition: all 0.35s ease;
      text-decoration: none;
      border: 2px solid transparent;
    }

    .btn-primary {
      background-color: var(--secondary-color);
      color: var(--primary-color);
    }

    .btn-primary:hover {
      background-color: #e0a030;
      transform: translateY(-2px);
      box-shadow: var(--shadow-hover);
    }

    .btn-ghost {
      border: 2px solid var(--secondary-color);
      color: var(--secondary-color);
      background-color: transparent;
    }

    .btn-ghost:hover {
      background-color: rgba(212, 175, 55, 0.1);
      transform: translateY(-2px);
    }

    .btn-arrow {
      transition: transform 0.35s ease;
    }

    .btn:hover .btn-arrow {
      transform: translateX(3px);
    }

    /* Navigation */
    header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background-color: transparent;
      transition: all 0.35s ease;
      border-bottom: 1px solid transparent;
    }

    header.scrolled {
      background-color: rgba(250, 251, 249, 0.95);
      backdrop-filter: blur(10px);
      border-bottom-color: var(--border-color);
      box-shadow: 0 2px 10px rgba(26, 42, 74, 0.05);
    }

    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: calc(var(--spacing-base) * 3) calc(var(--spacing-base) * 4);
      max-width: 1200px;
      margin: 0 auto;
    }

    .logo {
      font-size: 18px;
      font-weight: 600;
      color: var(--primary-color);
      letter-spacing: -0.01em;
    }

    .nav-links {
      display: flex;
      gap: calc(var(--spacing-base) * 6);
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .nav-links a {
      color: var(--text-color);
      font-weight: 500;
      font-size: 14px;
      position: relative;
      padding-bottom: 4px;
      display: inline-block;
    }

    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: 0;
      right: 0;
      width: 100%;
      height: 2px;
      background-color: var(--secondary-color);
      transform: scaleX(0);
      transform-origin: right;
      transition: transform 0.35s ease;
    }

    .nav-links a:hover::after {
      transform: scaleX(1);
      transform-origin: left;
    }

    .hamburger {
      display: none;
      flex-direction: column;
      gap: 6px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
    }

    .hamburger span {
      width: 24px;
      height: 2px;
      background-color: var(--primary-color);
      transition: all 0.35s ease;
    }

    .hamburger.active span:nth-child(1) {
      transform: rotate(45deg) translate(10px, 10px);
    }

    .hamburger.active span:nth-child(2) {
      opacity: 0;
    }

    .hamburger.active span:nth-child(3) {
      transform: rotate(-45deg) translate(7px, -7px);
    }

    /* Hero */
    .hero {
      position: relative;
      min-height: 90vh;
      display: flex;
      align-items: flex-end;
      padding: 0;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
    }

    .hero-bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      animation: heroZoom 1.6s ease-out;
    }

    @keyframes heroZoom {
      from {
        transform: scale(1.05);
        opacity: 0;
      }
      to {
        transform: scale(1);
        opacity: 1;
      }
    }

    .hero-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(180deg, rgba(26, 42, 74, 0.25) 0%, rgba(26, 42, 74, 0.78) 88%);
      z-index: 1;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      padding: calc(var(--spacing-base) * 6) calc(var(--spacing-base) * 4);
      max-width: 600px;
      animation: fadeInUp 1.2s ease-out 0.3s both;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .hero-eyebrow {
      color: var(--secondary-color);
      display: block;
      font-size: 12px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      margin-bottom: calc(var(--spacing-base) * 3);
    }

    .hero h1 {
      color: #ffffff;
      margin-bottom: calc(var(--spacing-base) * 3);
      font-size: 48px;
    }

    .hero-subhead {
      color: rgba(255, 255, 255, 0.95);
      font-size: 18px;
      margin-bottom: calc(var(--spacing-base) * 6);
      line-height: 1.6;
    }

    .hero-ctas {
      display: flex;
      gap: calc(var(--spacing-base) * 3);
      flex-wrap: wrap;
    }

    /* Sections */
    .section-alt {
      background-color: #f0ebe2;
    }

    .section-alt-2 {
      background-color: #fafbf9;
    }

    /* Cards */
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: calc(var(--spacing-base) * 6);
      margin-top: calc(var(--spacing-base) * 8);
    }

    .card {
      background-color: #ffffff;
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(26, 42, 74, 0.08);
      transition: all 0.35s ease;
      display: flex;
      flex-direction: column;
    }

    .card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-hover);
    }

    .card-image {
      width: 100%;
      aspect-ratio: 4/3;
      overflow: hidden;
    }

    .card-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease;
    }

    .card:hover .card-image img {
      transform: scale(1.06);
    }

    .card-body {
      padding: calc(var(--spacing-base) * 5);
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .card h3 {
      margin-bottom: calc(var(--spacing-base) * 2);
    }

    .card p {
      color: var(--text-light);
      margin-bottom: calc(var(--spacing-base) * 4);
      flex: 1;
    }

    .card-link {
      color: var(--secondary-color);
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: gap 0.35s ease;
    }

    .card-link:hover {
      gap: 10px;
    }

    /* About Section */
    .about-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: calc(var(--spacing-base) * 8);
      align-items: center;
    }

    .about-text h2 {
      margin-bottom: calc(var(--spacing-base) * 4);
    }

    .about-text p {
      color: var(--text-light);
      margin-bottom: calc(var(--spacing-base) * 3);
    }

    .profile-photo {
      width: 160px;
      height: 160px;
      border-radius: 50%;
      border: 4px solid var(--secondary-color);
      box-shadow: var(--shadow);
      object-fit: cover;
    }

    /* Contact Section */
    .contact-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: calc(var(--spacing-base) * 8);
    }

    .contact-form {
      display: flex;
      flex-direction: column;
      gap: calc(var(--spacing-base) * 4);
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: calc(var(--spacing-base) * 1);
    }

    .form-group label {
      font-weight: 500;
      font-size: 14px;
      color: var(--text-color);
    }

    .form-group input,
    .form-group textarea {
      padding: 12px calc(var(--spacing-base) * 3);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      font-family: inherit;
      font-size: 16px;
      transition: border-color 0.35s ease;
    }

    .form-group input:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--secondary-color);
    }

    .form-group textarea {
      resize: vertical;
      min-height: 140px;
    }

    .form-message {
      padding: calc(var(--spacing-base) * 3);
      border-radius: 6px;
      text-align: center;
      margin-top: calc(var(--spacing-base) * 2);
      display: none;
      font-size: 14px;
    }

    .form-message.success {
      background-color: #e8f5e9;
      color: #2e7d32;
      display: block;
    }

    .form-message.error {
      background-color: #ffebee;
      color: #c62828;
      display: block;
    }

    .contact-info {
      display: flex;
      flex-direction: column;
      gap: calc(var(--spacing-base) * 5);
    }

    .contact-info-block h3 {
      margin-bottom: calc(var(--spacing-base) * 2);
    }

    .contact-info-block p {
      color: var(--text-light);
      margin: 0;
    }

    .contact-info-block a {
      display: block;
      margin-top: calc(var(--spacing-base) * 1);
    }

    /* Footer */
    footer {
      background-color: var(--primary-color);
      color: #ffffff;
      padding: calc(var(--spacing-base) * 8) calc(var(--spacing-base) * 4);
    }

    footer .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 calc(var(--spacing-base) * 4);
    }

    .footer-content {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: calc(var(--spacing-base) * 6);
      margin-bottom: calc(var(--spacing-base) * 6);
    }

    .footer-section h3 {
      color: var(--secondary-color);
      margin-bottom: calc(var(--spacing-base) * 3);
      font-size: 16px;
    }

    .footer-section ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .footer-section li {
      margin-bottom: calc(var(--spacing-base) * 2);
    }

    .footer-section a {
      color: rgba(255, 255, 255, 0.8);
      font-size: 14px;
      transition: color 0.35s ease;
    }

    .footer-section a:hover {
      color: var(--secondary-color);
    }

    .footer-copyright {
      padding-top: calc(var(--spacing-base) * 6);
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      text-align: center;
      font-size: 12px;
      color: rgba(255, 255, 255, 0.6);
    }

    .footer-credit {
      margin-top: calc(var(--spacing-base) * 2);
    }

    /* Scroll Reveal */
    [data-scroll-reveal] {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }

    [data-scroll-reveal].revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* Responsive */
    @media (max-width: 768px) {
      h1 {
        font-size: 32px;
      }

      h2 {
        font-size: 20px;
      }

      section {
        padding: 60px calc(var(--spacing-base) * 3);
      }

      .nav-links {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        flex-direction: column;
        gap: 0;
        background-color: #fafbf9;
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.35s ease;
        box-shadow: 0 10px 30px rgba(26, 42, 74, 0.1);
      }

      .nav-links.active {
        max-height: 300px;
      }

      .nav-links li {
        border-bottom: 1px solid var(--border-color);
      }

      .nav-links a {
        display: block;
        padding: calc(var(--spacing-base) * 3) calc(var(--spacing-base) * 4);
      }

      .hamburger {
        display: flex;
      }

      .hero h1 {
        font-size: 36px;
      }

      .hero-content {
        max-width: 100%;
      }

      .hero-ctas {
        flex-direction: column;
        gap: calc(var(--spacing-base) * 2);
      }

      .btn {
        justify-content: center;
      }

      .about-content,
      .contact-content {
        grid-template-columns: 1fr;
      }

      .cards {
        grid-template-columns: 1fr;
      }

      .lead {
        font-size: 16px;
      }
    }

    @media (max-width: 480px) {
      section {
        padding: 40px calc(var(--spacing-base) * 2);
      }

      h1 {
        font-size: 24px;
      }

      h2 {
        font-size: 18px;
      }

      .container {
        padding: 0 calc(var(--spacing-base) * 2);
      }

      nav {
        padding: calc(var(--spacing-base) * 2) calc(var(--spacing-base) * 2);
      }

      .logo {
        font-size: 16px;
      }

      .hero h1 {
        font-size: 28px;
      }

      .hero-content {
        padding: calc(var(--spacing-base) * 4) calc(var(--spacing-base) * 2);
      }

      .section-header {
        margin-bottom: calc(var(--spacing-base) * 6);
      }
    }
  </style>
</head>
<body>
  {% include "header.njk" %}
  
  <main>
    {{ content | safe }}
  </main>
  
  {% include "footer.njk" %}
  
  {% if site.ga_id %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.ga_id }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.ga_id }}');
  </script>
  {% endif %}

  <script>
    // Sticky header on scroll
    const header = document.querySelector('header');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    });

    // Mobile menu toggle
    const hamburger = document.querySelector('.hamburger');
    const navLinks = document.querySelector('.nav-links');
    
    if (hamburger) {
      hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('active');
        navLinks.classList.toggle('active');
      });

      navLinks.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          hamburger.classList.remove('active');
          navLinks.classList.remove('active');
        });
      });
    }

    // Scroll reveal
    const observerOptions = {
      threshold: 0.12,
      rootMargin: '0px 0px -100px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('[data-scroll-reveal]').forEach(el => {
      observer.observe(el);
    });

    // Contact form
    const contactForm = document.getElementById('contactForm');
    if (contactForm) {
      contactForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(contactForm);
        const data = Object.fromEntries(formData);
        
        try {
          const response = await fetch('https://formsubmit.co/ajax/{{ site.email }}', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify(data)
          });
          
          const messageEl = document.getElementById('formMessage');
          if (response.ok) {
            messageEl.textContent = 'Thank you! Your message has been sent.';
            messageEl.classList.remove('error');
            messageEl.classList.add('success');
            contactForm.reset();
          } else {
            messageEl.textContent = 'Something went wrong. Please try again.';
            messageEl.classList.remove('success');
            messageEl.classList.add('error');
          }
        } catch (error) {
          const messageEl = document.getElementById('formMessage');
          messageEl.textContent = 'Error sending message. Please try again.';
          messageEl.classList.remove('success');
          messageEl.classList.add('error');
        }
      });
    }
  </script>
</body>
</html>
