<footer>
  <div class="container">
    <div class="footer-content">
      <div class="footer-section">
        <h3>About</h3>
        <p>{{ site.name }} explores the timeless wisdom of Hindu philosophy with clarity and depth.</p>
      </div>
      
      <div class="footer-section">
        <h3>Services</h3>
        <ul>
          {% for service in services %}
          <li><a href="#services">{{ service.name }}</a></li>
          {% endfor %}
        </ul>
      </div>
      
      <div class="footer-section">
        <h3>Connect</h3>
        <p>
          <a href="mailto:{{ site.email }}">{{ site.email }}</a><br>
          <a href="tel:{{ site.phone }}">{{ site.phone_display }}</a>
        </p>
        {% if site.linkedin %}
        <p>
          <a href="{{ site.linkedin }}" target="_blank">LinkedIn Profile</a>
        </p>
        {% endif %}
      </div>
    </div>
    
    <div class="footer-copyright">
      <p>&copy; 2026 {{ site.name }}. All rights reserved.</p>
      <p class="footer-credit">Photography via Unsplash.</p>
    </div>
  </div>
</footer>
