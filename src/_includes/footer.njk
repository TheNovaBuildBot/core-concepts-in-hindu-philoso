<footer>
  <div class="footer-content">
    <div class="footer-section">
      <h4>About</h4>
      <p>{{ site.name }}</p>
      <p style="font-size: 14px; color: rgba(255, 255, 255, 0.7); margin-top: 0.8em;">{{ site.specialty }}</p>
    </div>

    {% if services.length > 0 %}
    <div class="footer-section">
      <h4>Services</h4>
      <ul>
        {% for service in services %}
        <li><a href="#services">{{ service.name }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    <div class="footer-section">
      <h4>Contact</h4>
      <div class="info-item">
        <strong>Phone</strong>
        <a href="tel:{{ site.phone }}">{{ site.phone_display }}</a>
      </div>
      <div class="info-item">
        <strong>Email</strong>
        <a href="mailto:{{ site.email }}">{{ site.email }}</a>
      </div>
      <div class="info-item">
        <strong>Location</strong>
        <p>{{ site.address }}</p>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; 2026 {{ site.name }}. All rights reserved.</p>
    <p>Photography via Unsplash.</p>
  </div>
</footer>
